<view class="page data-v-ba19e650"><scroll-view scroll-y class="scroll data-v-ba19e650"><view class="card data-v-ba19e650"><view class="title data-v-ba19e650">荣誉榜管理</view><view class="sub data-v-ba19e650">管理员可新增比赛荣誉或段位荣誉</view></view><view wx:if="{{a}}" class="empty data-v-ba19e650">仅管理员可访问</view><view wx:else class="data-v-ba19e650"><view class="card data-v-ba19e650"><view class="form-row data-v-ba19e650"><text class="label data-v-ba19e650">荣誉类型</text><picker class="data-v-ba19e650" mode="selector" range="{{c}}" value="{{d}}" bindchange="{{e}}"><view class="picker data-v-ba19e650">{{b}}</view></picker></view><block wx:if="{{f}}"><input class="input data-v-ba19e650" placeholder="比赛名称（可选）" value="{{g}}" bindinput="{{h}}"/><input class="input data-v-ba19e650" placeholder="冠军昵称" value="{{i}}" bindinput="{{j}}"/><input class="input data-v-ba19e650" type="number" placeholder="参赛人数（4-32）" value="{{k}}" bindinput="{{l}}"/></block><block wx:else><input class="input data-v-ba19e650" placeholder="玩家昵称" value="{{m}}" bindinput="{{n}}"/><input class="input data-v-ba19e650" placeholder="段位名称（如：雀豪1）" value="{{o}}" bindinput="{{p}}"/></block><picker class="data-v-ba19e650" mode="date" value="{{r}}" bindchange="{{s}}"><view class="picker data-v-ba19e650">达成日期：{{q}}</view></picker><block wx:if="{{r0}}"><textarea class="textarea data-v-ba19e650" placeholder="备注（可选）" value="{{t}}" bindinput="{{v}}"/></block><view class="btn data-v-ba19e650" bindtap="{{w}}">上传荣誉</view></view><view class="card data-v-ba19e650"><view class="title-sm data-v-ba19e650">已上传荣誉</view><view wx:if="{{x}}" class="empty data-v-ba19e650">暂无记录</view><view wx:for="{{y}}" wx:for-item="item" wx:key="d" class="row data-v-ba19e650"><view class="info data-v-ba19e650"><text class="line data-v-ba19e650">{{item.a}}</text><text class="line sub data-v-ba19e650">{{item.b}}</text></view><view class="del data-v-ba19e650" bindtap="{{item.c}}">删除</view></view></view></view></scroll-view></view>