
.create-container.data-v-98f0e4ec {
  height: 100vh;
  background-color: #f8f8f8;
}
.form-scroll.data-v-98f0e4ec {
  height: 100%;
}

/* 分区样式 */
.form-section.data-v-98f0e4ec {
  background-color: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.section-title.data-v-98f0e4ec {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 类型选择样式 */
.type-options.data-v-98f0e4ec {
  display: flex;
  justify-content: space-around;
  margin-bottom: 10rpx;
}
.type-option.data-v-98f0e4ec {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  width: 200rpx;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}
.type-option.active.data-v-98f0e4ec {
  background-color: #e8f5e9;
  border-color: #07c160;
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}
.type-icon.data-v-98f0e4ec {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.type-option.active .type-icon.data-v-98f0e4ec {
  background-color: #07c160;
}
.type-icon-img.data-v-98f0e4ec {
  width: 60rpx;
  height: 60rpx;
}
.type-name.data-v-98f0e4ec {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}
.type-option.active .type-name.data-v-98f0e4ec {
  color: #07c160;
  font-weight: bold;
}

/* 表单项目样式 */
.form-item.data-v-98f0e4ec {
  margin-bottom: 40rpx;
  position: relative;
}
.form-item.data-v-98f0e4ec:last-child {
  margin-bottom: 0;
}
.form-label.data-v-98f0e4ec {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}
.form-input.data-v-98f0e4ec {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}
.form-input.data-v-98f0e4ec:focus {
  border-color: #07c160;
  background-color: white;
}
.placeholder.data-v-98f0e4ec {
  color: #999;
  font-size: 28rpx;
}
.form-tips.data-v-98f0e4ec {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 24rpx;
  color: #999;
}
.error-text.data-v-98f0e4ec {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 修复：时间选择器包装样式 */
.picker-wrapper.data-v-98f0e4ec {
  display: flex;
  gap: 20rpx;
}
.picker-item.data-v-98f0e4ec {
  flex: 1;
}
.picker-input.data-v-98f0e4ec {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}
.picker-input.data-v-98f0e4ec:active {
  background-color: #f0f0f0;
}
.time-text.data-v-98f0e4ec {
  font-size: 28rpx;
  color: #333;
}
.placeholder-text.data-v-98f0e4ec {
  color: #999;
}
.location-hint.data-v-98f0e4ec {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}
.arrow-right.data-v-98f0e4ec {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 人数选择器样式 */
.number-picker.data-v-98f0e4ec {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.number-control.data-v-98f0e4ec {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.number-btn.data-v-98f0e4ec {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}
.number-btn.data-v-98f0e4ec:active {
  background-color: #06ad56;
}
.number-btn.disabled.data-v-98f0e4ec {
  background-color: #cccccc;
  color: #999;
}
.number-btn.disabled.data-v-98f0e4ec:active {
  background-color: #cccccc;
}
.number-btn.minus.data-v-98f0e4ec {
  margin-right: 40rpx;
}
.number-btn.plus.data-v-98f0e4ec {
  margin-left: 40rpx;
}
.number-display.data-v-98f0e4ec {
  display: flex;
  align-items: baseline;
}
.number-value.data-v-98f0e4ec {
  font-size: 60rpx;
  font-weight: bold;
  color: #07c160;
  margin-right: 10rpx;
}
.number-unit.data-v-98f0e4ec {
  font-size: 28rpx;
  color: #666;
}
.number-tips.data-v-98f0e4ec {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 文本域样式 */
.form-textarea.data-v-98f0e4ec {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
  line-height: 1.5;
}
.form-textarea.data-v-98f0e4ec:focus {
  border-color: #07c160;
  background-color: white;
}

/* 预览卡片样式 */
.preview-card.data-v-98f0e4ec {
  margin-top: 20rpx;
}
.preview-info.data-v-98f0e4ec {
  display: flex;
  flex-direction: column;
