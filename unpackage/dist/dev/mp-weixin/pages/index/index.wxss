
.container.data-v-1cf27b2a {
  padding: 0;
}

/* 筛选栏样式 */
.filter-bar.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 20rpx 30rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
}
.type-tabs.data-v-1cf27b2a {
  width: 100%;
  white-space: nowrap;
  height: 80rpx;
}
.type-tab.data-v-1cf27b2a {
  display: inline-block;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
}
.type-tab.active.data-v-1cf27b2a {
  background-color: #07c160;
  color: white;
}
.action-row.data-v-1cf27b2a {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}
.create-btn.data-v-1cf27b2a {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #07c160;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  text-align: center;
  flex-shrink: 0;
}
.create-btn.data-v-1cf27b2a:active {
  background-color: #06ad56;
}

/* 组局列表样式 */
.game-list.data-v-1cf27b2a {
  height: calc(100vh - 180rpx);
}
.refresh-tip.data-v-1cf27b2a {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态样式 */
.empty-state.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.empty-image.data-v-1cf27b2a {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}
.empty-text.data-v-1cf27b2a {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.empty-btn.data-v-1cf27b2a {
  padding: 20rpx 40rpx;
  background-color: #07c160;
  color: white;
  border-radius: 10rpx;
  font-size: 30rpx;
}
.empty-btn.data-v-1cf27b2a:active {
  background-color: #06ad56;
}

/* 游戏卡片样式 */
.game-card.data-v-1cf27b2a {
  margin: 20rpx;
  padding: 30rpx;
}
.game-card.data-v-1cf27b2a:active {
  background-color: #f8f8f8;
}
.card-header.data-v-1cf27b2a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.game-type.data-v-1cf27b2a {
  display: flex;
  align-items: center;
}
.type-tag.data-v-1cf27b2a {
  padding: 6rpx 20rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.tag-mahjong.data-v-1cf27b2a {
  background-color: #e6f7ff;
  color: #1890ff;
}
.tag-boardgame.data-v-1cf27b2a {
  background-color: #f6ffed;
  color: #52c41a;
}
.tag-videogame.data-v-1cf27b2a {
  background-color: #fff7e6;
  color: #fa8c16;
}
.tag-competition.data-v-1cf27b2a {
  background-color: #f3e8ff;
  color: #7c3aed;
}
.status-tag.data-v-1cf27b2a {
  padding: 6rpx 20rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.tag-status.data-v-1cf27b2a {
  background-color: #e6f7ff;
  color: #1890ff;
}
.tag-status-full.data-v-1cf27b2a {
  background-color: #ffccc7;
  color: #ff4d4f;
}
.game-title.data-v-1cf27b2a {
  margin-bottom: 10rpx;
}
.title-text.data-v-1cf27b2a {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.game-project.data-v-1cf27b2a {
  margin-bottom: 20rpx;
}
.project-text.data-v-1cf27b2a {
  font-size: 30rpx;
  color: #666;
}

/* 活动信息样式 */
.game-info.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 20rpx;
}
.info-item.data-v-1cf27b2a {
  display: flex;
  align-items: center;
}
.info-icon.data-v-1cf27b2a {
  width: 32rpx;
  height: 32rpx;
  margin-right: 15rpx;
  opacity: 0.7;
}
.info-text.data-v-1cf27b2a {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

/* 玩家头像样式 */
.player-avatars.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar-item.data-v-1cf27b2a {
  margin-right: -15rpx;
}
.avatar.data-v-1cf27b2a {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid white;
}
.more-players.data-v-1cf27b2a {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮样式 */
.action-btn.data-v-1cf27b2a {
  display: flex;
  justify-content: flex-end;
}
.join-btn.data-v-1cf27b2a {
  padding: 15rpx 40rpx;
  background-color: #07c160;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
}
.join-btn.data-v-1cf27b2a:active {
  background-color: #06ad56;
}
.joined-btn.data-v-1cf27b2a {
  padding: 15rpx 40rpx;
  background-color: #cccccc;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
}
.full-btn.data-v-1cf27b2a {
  padding: 15rpx 40rpx;
  background-color: #ffccc7;
  color: #ff4d4f;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 1rpx solid #ff4d4f;
}

/* 加载提示样式 */
.loading-tip.data-v-1cf27b2a {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}
.load-more.data-v-1cf27b2a {
  text-align: center;
  padding: 30rpx;
  color: #07c160;
  font-size: 28rpx;
}
.load-more.data-v-1cf27b2a:active {
  opacity: 0.7;
}
.no-more.data-v-1cf27b2a {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}
