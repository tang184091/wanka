
.game-list-container.data-v-54b926a2 {
  height: 100vh;
  background-color: #f8f8f8;
}

/* 导航栏 */
.nav-bar.data-v-54b926a2 {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 20;
}
.nav-left.data-v-54b926a2 {
  width: 80rpx;
}
.nav-title.data-v-54b926a2 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
