  color: #374151;
  line-height: 1;
}

/* 筛选标签 */
.filter-tabs.data-v-54b926a2 {
  background-color: white;
  position: -webkit-sticky;
  position: sticky;
  top: 100rpx;
  z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.tabs-scroll.data-v-54b926a2 {
  white-space: nowrap;
  height: 100rpx;
  padding: 0 20rpx;
}
.tab-item.data-v-54b926a2 {
  display: inline-flex;
  align-items: center;
  height: 100rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}
.tab-item.active.data-v-54b926a2 {
  color: #07c160;
  font-weight: bold;
}
.tab-item.active.data-v-54b926a2::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  height: 4rpx;
  background-color: #07c160;
  border-radius: 2rpx;
}
.tab-text.data-v-54b926a2 {
  font-size: 28rpx;
}
.tab-count.data-v-54b926a2 {
  font-size: 24rpx;
  margin-left: 8rpx;
  opacity: 0.7;
}

/* 组局滚动区域 */
.game-scroll.data-v-54b926a2 {
  height: calc(100vh - 200rpx);
}

/* 空状态 */
.empty-state.data-v-54b926a2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}
.empty-text.data-v-54b926a2 {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.empty-btn.data-v-54b926a2 {
