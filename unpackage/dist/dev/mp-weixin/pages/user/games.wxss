
.games-container.data-v-69e18c5c {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

/* 导航栏 - 确保只有一个返回箭头 */
.nav-bar.data-v-69e18c5c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  position: relative;
  z-index: 1000;
}
.nav-left.data-v-69e18c5c {
  width: 80rpx;
}
.back-icon.data-v-69e18c5c {
  width: 40rpx;
  height: 40rpx;
}
.nav-title.data-v-69e18c5c {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
}
.nav-right.data-v-69e18c5c {
  width: 80rpx;
  text-align: right;
}
.save-text.data-v-69e18c5c {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 500;
}

/* 滚动区域 */
.games-scroll.data-v-69e18c5c {
  flex: 1;
  padding: 20rpx 30rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 分区样式 - 统一高度管理 */
.section.data-v-69e18c5c {
  margin-bottom: 40rpx;
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx; /* 增加内边距 */
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  min-height: 0; /* 允许自适应 */
  flex-shrink: 0; /* 防止压缩 */
}

/* 特别处理添加游戏区域，增加高度 */
.add-game-section.data-v-69e18c5c {
  min-height: 400rpx; /* 确保有足够的高度 */
  padding: 50rpx 40rpx; /* 增加内边距 */
}
.section-title.data-v-69e18c5c {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx; /* 增加底部间距 */
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0; /* 标题不压缩 */
}
.item-count.data-v-69e18c5c {
  font-size: 28rpx;
  color: #666;
  font-weight: normal;
}

/* 空状态 */
.empty-games.data-v-69e18c5c {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  flex: 1; /* 占据可用空间 */
}
.empty-image.data-v-69e18c5c {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.empty-text.data-v-69e18c5c {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* 游戏列表 */
.games-list.data-v-69e18c5c {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  flex: 1; /* 占据可用空间 */
  min-height: 0; /* 允许压缩 */
  overflow: visible;
}

/* 游戏项 */
.game-item.data-v-69e18c5c {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  min-height: 100rpx;
  box-sizing: border-box;
  flex-shrink: 0; /* 不压缩 */
}

/* 主要部分 */
.game-main.data-v-69e18c5c {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}
.game-type-tag.data-v-69e18c5c {
  width: 100rpx;
  text-align: center;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.game-tag-mahjong.data-v-69e18c5c {
  background-color: #e6f7ff;
  color: #1890ff;
}
.game-tag-boardgame.data-v-69e18c5c {
  background-color: #f6ffed;
  color: #52c41a;
}
.game-tag-videogame.data-v-69e18c5c {
  background-color: #fff7e6;
  color: #fa8c16;
}

/* 游戏名称输入框 */
.game-name-input.data-v-69e18c5c {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
  border: none;
  padding: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  height: 100%;
  display: flex;
  align-items: center;
}
.game-name-input.data-v-69e18c5c:focus {
  background-color: white;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  border: 1rpx solid #07c160;
  position: relative;
  z-index: 1;
  min-width: 300rpx;
  white-space: normal;
  overflow: auto;
  text-overflow: clip;
}
.placeholder.data-v-69e18c5c {
  color: #999;
  font-size: 28rpx;
}

/* 游戏操作按钮 */
.game-actions.data-v-69e18c5c {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}
.type-btn.data-v-69e18c5c,
.remove-btn.data-v-69e18c5c {
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}
.type-btn.data-v-69e18c5c {
  background-color: #1890ff;
  color: white;
}
.type-btn.data-v-69e18c5c:active {
  background-color: #096dd9;
}
.remove-btn.data-v-69e18c5c {
  background-color: #ff4d4f;
  color: white;
}
.remove-btn.data-v-69e18c5c:active {
  background-color: #ff7875;
}

/* 关键修复：添加游戏表单 - 解决高度压缩问题 */
.add-game-form.data-v-69e18c5c {
  display: flex;
  flex-direction: column;
  gap: 30rpx; /* 增加表单项间距 */
  width: 100%;
  flex: 1; /* 占据可用空间 */
  min-height: 300rpx; /* 确保最小高度 */
}
.form-item.data-v-69e18c5c {
  display: flex;
  flex-direction: column;
  gap: 15rpx; /* 增加标签和输入框间距 */
  width: 100%;
  flex-shrink: 0; /* 防止压缩 */
}
.form-label.data-v-69e18c5c {
  font-size: 30rpx; /* 稍微增大字体 */
  color: #333;
  font-weight: 500;
  width: 100%;
  flex-shrink: 0;
}
.form-picker.data-v-69e18c5c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx; /* 增加内边距 */
  background-color: #f8f8f8;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  min-height: 90rpx; /* 确保最小高度 */
  flex-shrink: 0;
}
.form-picker.data-v-69e18c5c:active {
  background-color: #f0f0f0;
}
.arrow-right.data-v-69e18c5c {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 关键修复：表单输入框 - 解决压缩问题 */
.form-input.data-v-69e18c5c {
  width: 100%;
  padding: 25rpx; /* 增加内边距 */
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  min-height: 90rpx; /* 确保最小高度 */
  flex-shrink: 0; /* 防止压缩 */
  display: block;
}
.form-input.data-v-69e18c5c:focus {
  border-color: #07c160;
  background-color: white;
  min-width: 300rpx;
}
.add-btn.data-v-69e18c5c {
  padding: 25rpx; /* 增加内边距 */
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 500;
  margin-top: 20rpx; /* 增加上边距 */
  width: 100%;
  box-sizing: border-box;
  min-height: 90rpx; /* 确保最小高度 */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.add-btn.data-v-69e18c5c:active {
  background-color: #06ad56;
}
.add-btn-disabled.data-v-69e18c5c {
  background-color: #ccc;
  color: #999;
  pointer-events: none;
}

/* 保存提示 */
.save-tips.data-v-69e18c5c {
  padding: 20rpx;
  background-color: #f6ffed;
  color: #52c41a;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  margin-top: 20rpx;
  border: 1rpx solid #b7eb8f;
  line-height: 1.4;
  width: 100%;
  box-sizing: border-box;
  flex-shrink: 0;
}
