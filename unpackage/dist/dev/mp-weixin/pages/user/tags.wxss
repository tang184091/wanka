
.tags-container.data-v-febbdecc { width: 100vw; min-height: 100vh; background-color: #f8f8f8; display: flex; flex-direction: column;
}
.nav-bar.data-v-febbdecc { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 30rpx; background-color: white; border-bottom: 1rpx solid #f0f0f0; position: -webkit-sticky; position: sticky; top: 0; z-index: 10;
}
.nav-left.data-v-febbdecc,.nav-right.data-v-febbdecc { width: 80rpx;
}
.nav-right.data-v-febbdecc { text-align: right;
}
.nav-text-btn.data-v-febbdecc { font-size: 28rpx; color: #374151; line-height: 1;
}
.nav-title.data-v-febbdecc { font-size: 36rpx; font-weight: bold; color: #333; flex: 1; text-align: center;
}
.save-text.data-v-febbdecc { font-size: 32rpx; color: #07c160; font-weight: 500;
}
.tags-scroll.data-v-febbdecc { flex: 1; padding: 20rpx 30rpx; box-sizing: border-box;
}
.section.data-v-febbdecc { margin-bottom: 40rpx; background-color: white; border-radius: 16rpx; padding: 30rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05);
}
.section-title.data-v-febbdecc { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #f0f0f0;
}
.tags-list.data-v-febbdecc { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 16rpx;
}
.tag-item.data-v-febbdecc { position: relative; background-color: #f0f0f0; color: #666; height: 72rpx; border-radius: 12rpx; font-size: 24rpx; border: 2rpx solid transparent; display: flex; align-items: center; justify-content: center; padding: 0 12rpx; box-sizing: border-box;
}
.tag-item.selected.data-v-febbdecc { background-color: #e6f7ff; color: #1890ff; border-color: #1890ff;
}
.tag-text.data-v-febbdecc { font-size: 24rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: center;
}
.tag-check.data-v-febbdecc { position: absolute; right: 6rpx; top: 6rpx; width: 24rpx; height: 24rpx; background-color: #1890ff; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16rpx; font-weight: bold;
}
.custom-tags.data-v-febbdecc { display: flex; flex-direction: column; gap: 20rpx;
}
.custom-tag-item.data-v-febbdecc { display: flex; align-items: center; gap: 20rpx;
}
.custom-tag-input.data-v-febbdecc { flex: 1; height: 80rpx; padding: 0 20rpx; background-color: #f8f8f8; border-radius: 8rpx; font-size: 28rpx; color: #333; border: 2rpx solid #e0e0e0; box-sizing: border-box;
}
.placeholder.data-v-febbdecc { color: #999; font-size: 28rpx;
}
.tag-remove.data-v-febbdecc { width: 60rpx; height: 60rpx; background-color: #ff4d4f; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx;
}
.add-tag-btn.data-v-febbdecc { padding: 20rpx; background-color: #f8f8f8; color: #07c160; border-radius: 8rpx; font-size: 28rpx; text-align: center; border: 2rpx dashed #07c160; margin-top: 10rpx;
}
.save-tips.data-v-febbdecc { padding: 20rpx; background-color: #fff7e6; color: #fa8c16; border-radius: 8rpx; font-size: 24rpx; text-align: center; margin-top: 20rpx; border: 1rpx solid #ffd591;
}
