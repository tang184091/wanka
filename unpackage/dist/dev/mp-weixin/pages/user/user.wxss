.user-container.data-v-0f7520f0 {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 100rpx;
}

/* 用户卡片样式 */
.user-card.data-v-0f7520f0 {
  margin: 20rpx;
  padding: 40rpx 30rpx;
}
.user-header.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.avatar-section.data-v-0f7520f0 {
  position: relative;
  margin-right: 30rpx;
}
.user-avatar.data-v-0f7520f0 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #07c160;
}
.avatar-edit.data-v-0f7520f0 {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: #07c160;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.user-base-info.data-v-0f7520f0 {
  flex: 1;
}
.nickname-section.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}
.nickname.data-v-0f7520f0 {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}
.edit-icon.data-v-0f7520f0 {
  background-color: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}
.user-id.data-v-0f7520f0 {
  font-size: 28rpx;
  color: #999;
}

/* 分区样式 */
.section.data-v-0f7520f0 {
  margin-bottom: 40rpx;
}
.section-header.data-v-0f7520f0 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title.data-v-0f7520f0 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 标签样式 */
.tags-container.data-v-0f7520f0,
.games-container.data-v-0f7520f0 {
  min-height: 60rpx;
}
.no-tags.data-v-0f7520f0,
.no-games.data-v-0f7520f0 {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
.tags-list.data-v-0f7520f0 {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.tag-item.data-v-0f7520f0 {
  background-color: #e6f7ff;
  color: #1890ff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

/* 游戏/装备样式 */
.games-list.data-v-0f7520f0 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.game-item.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx
}
.game-type-tag.data-v-0f7520f0 {
  width: 80rpx;
  text-align: center;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.game-tag-mahjong.data-v-0f7520f0 {
  background-color: #e6f7ff;
  color: #1890ff;
}
.game-tag-boardgame.data-v-0f7520f0 {
  background-color: #f6ffed;
  color: #52c41a;
}
.game-tag-videogame.data-v-0f7520f0 {
  background-color: #fff7e6;
  color: #fa8c16;
}
.game-tag-deck.data-v-0f7520f0 {
  background-color: #f3e8ff;
  color: #7c3aed;
}
.game-tag-other.data-v-0f7520f0 {
  background-color: #f1f5f9;
  color: #475569;
}
.game-name.data-v-0f7520f0 {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}
.honor-list.data-v-0f7520f0 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.honor-item.data-v-0f7520f0 {
  background-color: #f8fafc;
  border-radius: 10rpx;
  padding: 14rpx;
}
.honor-head.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.honor-rarity.data-v-0f7520f0 {
  min-width: 84rpx;
  text-align: center;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.honor-legend.data-v-0f7520f0 {
  background: linear-gradient(135deg, #f59e0b, #fcd34d);
  color: #7c2d12;
}
.honor-epic.data-v-0f7520f0 {
  background: linear-gradient(135deg, #7c3aed, #8b5cf6);
  color: #fff;
}
.honor-rare.data-v-0f7520f0 {
  background: linear-gradient(135deg, #2563eb, #38bdf8);
  color: #fff;
}
.honor-common.data-v-0f7520f0 {
  background: #fff;
  color: #111827;
  border: 1rpx solid #111827;
}
.honor-time.data-v-0f7520f0 {
  font-size: 22rpx;
  color: #6b7280;
}
.honor-title.data-v-0f7520f0 {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #1f2937;
}

/* 统计数据样式 */
.stats-section.data-v-0f7520f0 {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-top: 20rpx;
}
.stat-item.data-v-0f7520f0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.stat-value.data-v-0f7520f0 {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 10rpx;
}
.stat-label.data-v-0f7520f0 {
  font-size: 24rpx;
  color: #666;
}
.stat-divider.data-v-0f7520f0 {
  width: 1rpx;
  height: 40rpx;
  background-color: #e0e0e0;
}

/* 菜单列表样式 */
.menu-list.data-v-0f7520f0 {
  background-color: white;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item.data-v-0f7520f0 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  min-height: 96rpx;
  box-sizing: border-box;
  background-color: white;
}
.menu-item.data-v-0f7520f0:active {
  background-color: #f8f8f8;
}
.share-menu-item.data-v-0f7520f0 {
  width: 100%;
  margin: 0;
  padding: 30rpx;
  border: none;
  border-radius: 0;
  background-color: #fff;
  text-align: left;
}
.share-menu-item.data-v-0f7520f0::after {
  border: none;
}
.menu-left.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}
.menu-text.data-v-0f7520f0 {
  font-size: 32rpx;
  color: #333;
}
.menu-right.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 120rpx;
  flex-shrink: 0;
}
.menu-count.data-v-0f7520f0 {
  font-size: 28rpx;
  color: #999;
  margin-right: 20rpx;
}
.menu-arrow.data-v-0f7520f0 {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1;
}
.menu-divider.data-v-0f7520f0 {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 0 30rpx;
}

/* 登录按钮样式 */
.login-btn-container.data-v-0f7520f0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  padding: 0 60rpx;
}
.login-btn.data-v-0f7520f0 {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background-color: #07c160;
  color: white;
  padding: 25rpx 0;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}
.login-btn.data-v-0f7520f0:active {
  background-color: #06ad56;
}
.login-text.data-v-0f7520f0 {
  font-size: 32rpx;
}
.login-tip.data-v-0f7520f0 {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 退出登录按钮 */
.logout-container.data-v-0f7520f0 {
  padding: 40rpx 30rpx;
}
.logout-btn.data-v-0f7520f0 {
  width: 100%;
  background-color: #ff4d4f;
  color: white;
  text-align: center;
  padding: 25rpx 0;
  border-radius: 10rpx;
  font-size: 32rpx;
}
.logout-btn.data-v-0f7520f0:active {
  background-color: #ff7875;
}
