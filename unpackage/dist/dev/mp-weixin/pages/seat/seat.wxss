
.seat-page.data-v-f89a1d25 {
  min-height: 100vh;
  background: #f5f6f7;
}
.seat-scroll.data-v-f89a1d25 {
  height: 100vh;
}
.layout-card.data-v-f89a1d25 {
  margin: 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #eef1f3;
  padding: 24rpx;
}
.layout-header.data-v-f89a1d25 {
  margin-bottom: 16rpx;
}
.layout-title.data-v-f89a1d25 {
  display: block;
  font-size: 34rpx;
  color: #1f2937;
  font-weight: 700;
}
.layout-subtitle.data-v-f89a1d25 {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}
.legend-row.data-v-f89a1d25 {
  display: flex;
  gap: 20rpx;
  margin-bottom: 18rpx;
}
.legend-item.data-v-f89a1d25 {
  display: flex;
  align-items: center;
}
.legend-dot.data-v-f89a1d25 {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}
.dot-available.data-v-f89a1d25 { background: #40c057;
}
.dot-occupied.data-v-f89a1d25 { background: #ff6b6b;
}
.dot-reserved.data-v-f89a1d25 { background: #f59f00;
}
.legend-text.data-v-f89a1d25 {
  font-size: 22rpx;
  color: #4b5563;
}
.zone.data-v-f89a1d25 {
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  margin-bottom: 12rpx;
}
.corridor.data-v-f89a1d25 {
  text-align: center;
  font-size: 26rpx;
  color: #374151;
  background: #dee2e6;
  padding: 14rpx 0;
}
.top-grid.data-v-f89a1d25,
.lower-grid.data-v-f89a1d25 {
  display: grid;
  gap: 10rpx;
  padding: 10rpx;
}
.top-grid.data-v-f89a1d25 {
  grid-template-columns: repeat(3, 1fr);
}
.lower-grid.data-v-f89a1d25 {
  grid-template-columns: repeat(2, 1fr);
}
.hall-title.data-v-f89a1d25 {
  text-align: center;
  font-size: 26rpx;
  color: #374151;
  background: #f8f9fa;
  padding: 14rpx 0;
}
.hall-grid.data-v-f89a1d25 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  padding: 10rpx;
}
.room-cell.data-v-f89a1d25,
.seat-cell.data-v-f89a1d25 {
  border-radius: 10rpx;
  border: 2rpx solid transparent;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  transition: transform 0.2s ease;
}
.room-cell.data-v-f89a1d25:active,
.seat-cell.data-v-f89a1d25:active {
  transform: scale(0.98);
}
.room-name.data-v-f89a1d25,
.seat-name.data-v-f89a1d25 {
  display: block;
  text-align: center;
  color: #1f2937;
  font-size: 22rpx;
  font-weight: 600;
}
.room-status.data-v-f89a1d25 {
  display: block;
  text-align: center;
  margin-top: 6rpx;
  color: #4b5563;
  font-size: 20rpx;
}

/* 类型色：按你的要求 */
.type-videogame.data-v-f89a1d25 { background: rgba(255, 107, 107, 0.14); border-color: rgba(255, 107, 107, 0.4);
}
.type-boardgame.data-v-f89a1d25 { background: rgba(77, 171, 247, 0.14); border-color: rgba(77, 171, 247, 0.4);
}
.type-mahjong.data-v-f89a1d25 { background: rgba(64, 192, 87, 0.14); border-color: rgba(64, 192, 87, 0.4);
}
.status-available.data-v-f89a1d25 { box-shadow: inset 0 0 0 2rpx rgba(64, 192, 87, 0.3);
}
.status-occupied.data-v-f89a1d25 { box-shadow: inset 0 0 0 2rpx rgba(255, 107, 107, 0.3);
}
.status-reserved.data-v-f89a1d25 { box-shadow: inset 0 0 0 2rpx rgba(245, 159, 0, 0.3);
}

/* 深色模式 */
@media (prefers-color-scheme: dark) {
.seat-page.data-v-f89a1d25 { background: #101114;
}
.layout-card.data-v-f89a1d25 {
    background: #1a1c20;
    border-color: #2a2d34;
    box-shadow: none;
}
.layout-title.data-v-f89a1d25 { color: #f3f4f6;
}
.layout-subtitle.data-v-f89a1d25,
  .legend-text.data-v-f89a1d25,
  .room-status.data-v-f89a1d25 { color: #d1d5db;
}
.room-name.data-v-f89a1d25,
  .seat-name.data-v-f89a1d25 { color: #f3f4f6;
}
.zone.data-v-f89a1d25 { border-color: #2d3139;
}
.hall-title.data-v-f89a1d25 { background: #252932; color: #e5e7eb;
}
.corridor.data-v-f89a1d25 { background: #3b4048; color: #e5e7eb;
}
}
